# ------------------------------------------------------------
# NIMBUS MONOREPO GITIGNORE
# ------------------------------------------------------------

# --- Python & Data Engineering ---
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# --- Databases (Keep the code, ignore the heavy data) ---
*.db
*.sqlite3
database/*.duckdb
database/*.db
data/raw/
data/processed/

# --- Node / Next.js (Handles root or subfolders like /dashboard) ---
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/
**/.vercel
**/.pnp
**/.pnp.*
**/.yarn/*
!**.yarn/patches
!**.yarn/plugins
!**.yarn/releases
!**.yarn/versions

# --- Environment Variables (CRITICAL: Protects your Claude API Key) ---
.env
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Logs & Debugging ---
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/coverage/

# --- TypeScript ---
**/*.tsbuildinfo
**/next-env.d.ts

# --- OS / System Files ---
.DS_Store
Thumbs.db
*.pem

# --- Editor / IDE ---
.vscode/
.idea/